# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/tabibma
DATABASE_USERNAME=tabibma
DATABASE_PASSWORD=changeme

# docker-compose host port overrides — only needed if the defaults (8080/5432)
# collide with another project already running on your machine.
# BACKEND_HOST_PORT=8080
# DB_HOST_PORT=5432

# Auth — RS256 per docs/security-tabib-ma.md Section 3.
# Generate a dev keypair with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
# Then base64 the PEM contents (one line) into the vars below.
JWT_PRIVATE_KEY_B64=changeme-base64-encoded-pkcs8-private-key-pem
JWT_PUBLIC_KEY_B64=changeme-base64-encoded-x509-public-key-pem
JWT_EXPIRATION=900000
REFRESH_TOKEN_EXPIRATION=2592000000

# Spring
SPRING_PROFILES_ACTIVE=dev

# CORS / Frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# CMI Payment Gateway
CMI_MERCHANT_ID=changeme
CMI_API_KEY=changeme
CMI_CALLBACK_URL=http://localhost:8080/api/payments/cmi/callback

# WebRTC (TURN server for video consults)
WEBRTC_TURN_URL=turn:changeme.example.com:3478
WEBRTC_TURN_USERNAME=changeme
WEBRTC_TURN_CREDENTIAL=changeme

# Email (appointment confirmations, password reset)
SMTP_HOST=changeme
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASSWORD=changeme

# SMS (appointment reminders)
SMS_PROVIDER_API_KEY=changeme

# Redis (caching, doctor availability, sessions)
REDIS_URL=redis://localhost:6379
